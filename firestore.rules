rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Checks that the signed-in user's email exists in allowedAccounts
    // and the document has active == true.
    function isAllowedEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/allowedAccounts/$(request.auth.token.email));
    }

    // ---------------------------------------------------------------------------
    // /allowedAccounts/{email}
    //
    // A signed-in user may only read their own allowlist entry.
    // No client writes — managed via Firebase Console or Admin SDK.
    // ---------------------------------------------------------------------------
    match /allowedAccounts/{email} {
      allow read: if isSignedIn() && request.auth.token.email == email;
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // /users/{uid}
    //
    // Read and write only by the document owner AND only when their email
    // is present in allowedAccounts.
    // ---------------------------------------------------------------------------
    match /users/{uid} {
      allow read, write: if isOwner(uid) && isAllowedEmail();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
